<UserControl 
    x:Class="RussianNationalMessengerClient.Views.Pages.ChatsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:RussianNationalMessengerClient.Views.Pages"
    xmlns:helpers="clr-namespace:RussianNationalMessengerClient.Helpers"
    xmlns:converters="clr-namespace:RussianNationalMessengerClient.Converters"
    mc:Ignorable="d" Background="White"
    x:Name="ChatsPageRoot"
    d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisCon"/>
    </UserControl.Resources>
    
    <Grid ColumnDefinitions="1* 4*">
        <Border BorderBrush="gray" BorderThickness="0 0 0.5 0">
            <Grid RowDefinitions="auto, *">
                <Grid ColumnDefinitions="*, *, *" Margin="5">
                    <Button HorizontalAlignment="Left" Content="Меню" />
                    <TextBox Grid.Column="1" Grid.ColumnSpan="2" helpers:FocusHelper.IsFocused="{Binding IsFocusedTbSearch, Mode=TwoWay}"
                             Text="{Binding SearchUserContent, UpdateSourceTrigger=PropertyChanged}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="TextChanged">
                                <i:InvokeCommandAction Command="{Binding SearchUserCommand}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </TextBox>
                </Grid>
                
                <ListView Grid.Row="1" ItemsSource="{Binding Chats}" HorizontalContentAlignment="Stretch" 
                          SelectedItem="{Binding SelectedChat}" Visibility="{Binding VisibilityChatsLV}">

                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Удалить чат" Command="{Binding DeleteChatCommand}"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid RowDefinitions="* *">
                                <Label Content="{Binding DisplayName}"/>
                                <Grid Grid.Row="1" ColumnDefinitions="auto, *">
                                    <Label Content="{Binding LastMessageAuthor}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding LastMessageContent}" 
                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <ListView Grid.Row="1" ItemsSource="{Binding SearchUsers}" SelectedItem="{Binding SelectedAccount}"
                          Visibility="{Binding IsFocusedTbSearch, Converter={StaticResource BoolToVisCon}}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" Text="{Binding Username}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
        
        <ContentControl Grid.Column="1"
            Content="{Binding SelectedChat}"/>
    </Grid>
</UserControl>
