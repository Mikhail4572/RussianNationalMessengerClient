<UserControl x:Class="RussianNationalMessengerClient.Views.Pages.DialogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RussianNationalMessengerClient.Views.Pages"
      xmlns:vm="clr-namespace:RussianNationalMessengerClient.ViewModels"
      xmlns:views="clr-namespace:RussianNationalMessengerClient.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Background="#f1f1f1" RowDefinitions="auto, *, auto">
        <Grid ColumnDefinitions="auto, *">
            <Grid RowDefinitions="*, auto">
                <!--Имя собеседника-->
                <Label Content="{Binding DisplayName}" FontSize="15"/>
                <!--Онлайн ли?-->
                <Label Content="тест" Grid.Row="1" HorizontalContentAlignment="Right"/>
            </Grid>
        </Grid>
        
        <!--Чат-->
        <ListView Grid.Row="1" HorizontalContentAlignment="Stretch" ItemsSource="{Binding Messages}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border HorizontalAlignment="Left" BorderThickness="1" CornerRadius="8">
                        <Grid RowDefinitions="auto, *, auto" MaxWidth="200">
                            <Label Foreground="LightGray" Content="{Binding Author}" FontSize="12"/>
                            <TextBlock TextWrapping="Wrap" 
                                       Text="{Binding Content}"
                                       Grid.Row="1" FontSize="15"/>
                            <Label Grid.Row="2" Content="{Binding SentAtFormat}"/>
                        </Grid>
                    </Border>            
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        
        <Grid Grid.Row="2" ColumnDefinitions="6*, 1*" Margin="5">
            <TextBox Text="{Binding DataContext.Content, 
                RelativeSource={RelativeSource AncestorType=views:ChatsPage}}" 
                     FontSize="15" Padding="2" Margin="0 0 15 0"/>
            
            <Button Content="Отправить" Command="{Binding DataContext.SendMessageCommand,
                RelativeSource={RelativeSource AncestorType=views:ChatsPage}}" 
                    Grid.Column="1" Padding="5"/>
        </Grid>
    </Grid>
</UserControl>
