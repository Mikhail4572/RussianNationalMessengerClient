<Page x:Class="RussianNationalMessengerClient.Views.Pages.DialogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RussianNationalMessengerClient.Views.Pages"
      xmlns:vm="clr-namespace:RussianNationalMessengerClient.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DialogPage">
    <Page.DataContext>
        <vm:DialogViewModel/>
    </Page.DataContext>
    
    <Grid Background="#f1f1f1" RowDefinitions="auto, *, auto">
        <Grid Margin="10" ColumnDefinitions="auto, *">
            <Grid RowDefinitions="*, auto">
                <!--Имя собеседника-->
                <Label Content="тест" FontSize="15"/>
                <!--Онлайн ли?-->
                <Label Content="тест" Grid.Row="1" HorizontalContentAlignment="Right"/>
            </Grid>
        </Grid>
        <!--Чат-->
        <ListView Grid.Row="1"></ListView>
        
        <Grid Grid.Row="2" ColumnDefinitions="6*, 1*" Margin="5">
            <TextBox FontSize="15" Padding="2" Margin="0 0 15 0"/>
            <Button Content="Отправить" Grid.Column="1" Padding="5"/>
        </Grid>
    </Grid>
</Page>
