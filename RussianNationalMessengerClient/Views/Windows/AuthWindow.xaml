<Window x:Class="RussianNationalMessengerClient.Views.Windows.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RussianNationalMessengerClient.Views.Windows"
        xmlns:vm="clr-namespace:RussianNationalMessengerClient.ViewModels"
        xmlns:helpers="clr-namespace:RussianNationalMessengerClient.Classes"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Background="Transparent" WindowStartupLocation="CenterScreen"
        mc:Ignorable="d" ResizeMode="NoResize" WindowStyle="None"
        Title="AuthWindow" Height="450" Width="400">
    <Window.DataContext>
        <vm:AuthViewModel/>
    </Window.DataContext>

    <Grid Background="white" ColumnDefinitions="1*, 2.5*, 1*"
          RowDefinitions="auto, *">

        <Button Command="{Binding CloseCommand}" Grid.Column="2">
            <Button.Content>
                <svgc:SvgViewbox Source="Icons/closeIcon.svg"/>
            </Button.Content>
            <Button.Resources>
                <Style TargetType="Button">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Height" Value="20"/>
                    <Setter Property="Padding" Value="5 2"/>
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="HorizontalAlignment" Value="Right"/>
                </Style>
            </Button.Resources>
        </Button>

        <Grid Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"
              RowDefinitions="auto, auto, auto, auto, auto, auto, auto">
            <Label Content="Вход" FontSize="30" HorizontalContentAlignment="Center"/>
            <Label FontSize="15" Grid.Row="1" Content="Логин"/>
            <TextBox Text="{Binding Login.UserName}" Grid.Row="2"/>
            <Label FontSize="15" Grid.Row="3" Content="Пароль"/>
            <PasswordBox helpers:PasswordBoxHelper.Password="{Binding Login.Password, Mode=TwoWay}" Grid.Row="4"/>
            <Button Command="{Binding LoginCommand}" Content="Войти" Grid.Row="5"/>
            <ProgressBar Value="{Binding Value}" Maximum="100" Minimum="0" Height="10" Grid.Row="6"/>
        </Grid>

    </Grid>
</Window>
